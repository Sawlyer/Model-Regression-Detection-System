OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Optional: override the model set in the prompt YAML for every run.
# Any OpenRouter slug, e.g. nvidia/nemotron-3.5-content-safety:free
OPENROUTER_MODEL=
